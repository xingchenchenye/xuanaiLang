术 安全除(a: 整, b: 整) {
    试 {
        若 b == 0 {
            抛 {"类型": "业务异常", "信息": "除数不能为零"}；
        }
        返 a / b；
    } 捕 错 {
        返 错；
    }
}

令 正常 = 安全除(8, 2)；
令 业务错 = 安全除(8, 0)；

令 断言错 = 空；
试 {
    断 假, "手动断言失败"；
} 捕 错 {
    断言错 = 错；
}

令 运行错 = 空；
试 {
    令 值 = [1, 2][5]；
} 捕 错 {
    运行错 = 错；
}

断 正常 == 4；
断 业务错["类型"] == "业务异常"；
断 业务错["信息"] == "除数不能为零"；
断 断言错 == "手动断言失败"；
断 运行错["类型"] == "IndexError"；

显("异常演示:", 业务错, 断言错, 运行错)；
